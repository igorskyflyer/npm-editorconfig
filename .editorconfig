root = true

[*]
charset = utf-8
indent_style = space
indent_size = 2
end_of_line = lf
trim_trailing_whitespace = true
insert_final_newline = true

[*.{bat,cmd}]
end_of_line = crlf

[*.ps1]
end_of_line = crlf

[*.md]
trim_trailing_whitespace = false

[*.{yml,yaml}]
indent_size = 2

[*.json]
indent_size = 2

[*.toml]
indent_size = 2

[*.xml]
indent_size = 2

[*.svg]
indent_size = 2

[Makefile]
indent_style = tab

[*.{mk,make}]
indent_style = tab

[*.go]
indent_style = tab

[*.sh]
end_of_line = lf

[*.{gradle,groovy}]
indent_size = 4

[*.java]
indent_size = 4

[*.py]
indent_size = 4
